<?import javafx.scene.layout.StackPane?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.samplejavafxproject.HelloController">
    <VBox alignment="CENTER" fx:id="screen">
        <HBox alignment="CENTER">
            <VBox alignment="CENTER_LEFT">
                <Pane fx:id="pane1" prefWidth="400" prefHeight="300"/>
                <Pane fx:id="pane2" prefWidth="400" prefHeight="300"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Pane fx:id="pane3" prefWidth="400" prefHeight="300"/>
                <Pane fx:id="pane4" prefWidth="400" prefHeight="300"/>
            </VBox>
        </HBox>
        <HBox alignment="CENTER">
            <Button text="Click" fx:id="b1"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Click" fx:id="b2"/>
        </HBox>
    </VBox>
    <Pane fx:id="bPane" mouseTransparent="true"/>
</StackPane>


