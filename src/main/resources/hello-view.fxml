<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.image.ImageView?>

<?import com.example.samplejavafxproject.Player?>


<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.layout.StackPane?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.samplejavafxproject.HelloController">
    <VBox alignment="CENTER" fx:id="screen">
        <HBox alignment="CENTER">
            <VBox alignment="CENTER" prefWidth="400">
                <Label fx:id="timer1" text="15.0" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Button text="Click" fx:id="b1"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER" prefWidth="400">
                <Label fx:id="timer2" text="15.0" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Button text="Click" fx:id="b2"/>
            </VBox>
        </HBox>
        <Region minHeight="100"/>
        <HBox alignment="CENTER">
            <VBox alignment="CENTER_LEFT">
                <Pane fx:id="pane1" prefWidth="400" prefHeight="300"/>
                <Pane fx:id="pane2" prefWidth="400" prefHeight="300"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Pane fx:id="pane3" prefWidth="400" prefHeight="300"/>
                <Pane fx:id="pane4" prefWidth="400" prefHeight="300"/>
            </VBox>
        </HBox>
    </VBox>
    <Pane fx:id="bPane" mouseTransparent="true"/>
</StackPane>


